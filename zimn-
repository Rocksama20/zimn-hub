-- Tạo Tab Buttons
local function createTabButton(tabData, index)
    local tabBtn = Instance.new("TextButton")
    tabBtn.Name = tabData.name .. "Tab"
    tabBtn.Size = UDim2.new(0, 115, 1, 0)
    tabBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    tabBtn.BorderSizePixel = 0
    tabBtn.Text = tabData.label
    tabBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
    tabBtn.TextSize = 14
    tabBtn.Font = Enum.Font.GothamSemibold
    tabBtn.LayoutOrder = index
    tabBtn.Parent = tabContainer
    
    tabBtn.MouseButton1Click:Connect(function()
        currentTab = tabData.name
        contentText.Text = tabData.content
        
        -- Update all tab colors
        for _, child in pairs(tabContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
                child.TextColor3 = Color3.fromRGB(180, 180, 180)
            end
        end
        
        -- Highlight active tab
        tabBtn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    
    if index == 1 then
        tabBtn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

for i, tab in ipairs(tabs) do
    createTabButton(tab, i)
end

-- Dragging functionality
local dragging = false
local dragStart = nil
local startPos = nil

header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

header.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- Toggle function
local function toggleHub()
    isOpen = not isOpen
    mainFrame.Visible = isOpen
    
    if isOpen then
        mainFrame.Size = UDim2.new(0, 0, 0, 0)
        local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        local tween = TweenService:Create(mainFrame, tweenInfo, {Size = UDim2.new(0, 600, 0, 400)})
        tween:Play()
    end
end

-- Close button
closeBtn.MouseButton1Click:Connect(toggleHub)

-- Keyboard toggle (K key)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.K then
        toggleHub()
    end
end)

